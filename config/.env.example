# 喵言汪语 V3 · 环境变量模板
# 复制为 .env 并填入实际值：
#   cp config/.env.example config/.env
#
# 所有配置项均可通过环境变量覆盖。

# ── GPU 推理服务 ──
# 显卡妹(qwen35b) 运行的地址。3080 单端口，xianka/douhua 共享。
GATEWAY_URL=http://<YOUR_GPU_SERVER>:8080

# 模型名
XIANKA_MODEL=qwen35b
DOUHUA_MODEL=qwen35b

# Auth token（本地端口无需认证，留空）
GATEWAY_AUTH=

# ── 代理 ──
# 用于 Crawl4AI 抓取 PubMed/arXiv/Wikipedia 等
PROXY=http://<YOUR_PROXY>:7897

# ── 种子方向（可选） ──
# 不设置则使用 config/series_definitions.py 默认值
# SERIES_DIRECTION_B=犬类行为学、动物认知、沟通简史
# SERIES_DIRECTION_R=宠物科技市场、竞品分析、投资趋势
# SERIES_DIRECTION_M=按钮训练方法论、实操指南
# SERIES_DIRECTION_S=动物视角叙事、宠物故事
# SERIES_DIRECTION_Q=宠物沟通问答、训练疑虑
# SERIES_DIRECTION_F=趣味内容、宠物搞笑行为
# SERIES_DIRECTION_P=人物故事、行业人物
