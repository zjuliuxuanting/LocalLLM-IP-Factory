# 喵言汪语 · 环境变量
# 3080 单端口模式：xianka/douhua 共用同一端口，通过 temperature 区分行为

# Gateway 地址（3080 推理服务，单端口）
GATEWAY_URL=http://<GPU_SERVER_IP>:8080

# 模型名（3080 上只有一个 qwen35b）
XIANKA_MODEL=qwen35b
DOUHUA_MODEL=qwen35b

# Auth token（3080 本地端口无需认证，留空即可）
GATEWAY_AUTH=

# 代理（用于抓取 PubMed/arXiv/Wikipedia）
PROXY=http://<NAS_IP>:7890
